;;;
;;; PgBouncer configuration for bita_platform_backend
;;;
;;; Connection flow:
;;;
;;;   [HTTP users]
;;;         |  (nginx — HTTP/HTTPS, no DB connection)
;;;   [Gunicorn/Uvicorn workers]  — small fixed process pool
;;;         |  (opens a DB connection only during a transaction)
;;;   [PgBouncer]  ← max_client_conn limits this hop
;;;         |  (reuses a small pool of real PostgreSQL connections)
;;;   [PostgreSQL / RDS]  ← default_pool_size * pools <= max_connections
;;;

[databases]
;; Wildcard: proxy all databases to the configured backend.
* = host={{ pgbouncer_db_host }} port={{ pgbouncer_db_port | default(5432) }}

[pgbouncer]

;;;
;;; Where to wait for clients
;;;
listen_addr = 127.0.0.1
listen_port = 6432

unix_socket_dir = /var/run/postgresql

logfile = /var/log/postgresql/pgbouncer.log
pidfile = /var/run/postgresql/pgbouncer.pid

;;;
;;; Authentication
;;;
auth_type = md5
auth_file = /etc/pgbouncer/userlist.txt

admin_users = postgres,ubuntu

;;;
;;; Server-side TLS (PgBouncer → RDS)
;;;
server_tls_sslmode = require

;;;
;;; Pool settings
;;;
pool_mode = transaction

ignore_startup_parameters = extra_float_digits

max_prepared_statements = 0

server_reset_query = DISCARD ALL

;;;
;;; Connection limits
;;;
max_client_conn = 10000

default_pool_size = 1500

min_pool_size = 100

reserve_pool_size = 200

reserve_pool_timeout = 1

;;;
;;; Timeouts
;;;
server_idle_timeout = 600
server_lifetime = 3600
server_connect_timeout = 15
server_login_retry = 15

query_wait_timeout = 30

;;;
;;; Logging
;;;
log_connections = 1
log_disconnections = 1
log_pooler_errors = 1
log_stats = 1
stats_period = 60
