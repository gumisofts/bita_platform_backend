DJANGO_POSTGRES_URL=
DJANGO_ALLOWED_HOSTS=
DJANGO_SECRET_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=eu-north-1
AWS_STORAGE_BUCKET_NAME=

DJANGO_DEBUG=True

STATIC_URL=/static/

GOOGLE_WEB_CLIENT_ID=

GOOGLE_APPLICATION_CREDENTIALS=

DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

DJANGO_CELERY_BACKEND_URL=
DJANGO_CELERY_BROKER_URL=

TELEGRAM_BOT_TOKEN=

# Public base URL of the Mini App / web frontend (no trailing slash), used to
# build the "connect your Telegram" magic link emailed to users.
FRONTEND_URL=

# --- Email ---
# Leave EMAIL_HOST blank in development to print emails (and verification codes)
# to the console. Set these for real SMTP delivery in production.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL falls back to EMAIL_HOST_USER when unset.
DEFAULT_FROM_EMAIL=
# EMAIL_USE_SSL/TLS are inferred from the port (465 -> SSL, else STARTTLS); override if needed.
# EMAIL_USE_SSL=
# EMAIL_USE_TLS=
# Force the backend (otherwise: console in DEBUG, SMTP in production).
# EMAIL_BACKEND=
# Send email via Celery (defaults: off in DEBUG, on in production).
# EMAIL_USE_CELERY=
